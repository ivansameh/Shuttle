# Ignore dependencies
node_modules
**/node_modules

# Ignore build artifacts
dist
**/dist
build
**/build

# Ignore environment files and secrets
.env
.env.*
certs/*.key
certs/*.crt
certs/*.pem

# Ignore git and system files
.git
.gitignore
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode
.idea
.agent
.gemini

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
