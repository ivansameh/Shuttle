enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TripInstance {
  id             String         @id @default(uuid()) @db.Uuid
  
  lineId         String         @db.Uuid
  line           Line           @relation(fields: [lineId], references: [id])
  
  driverId       String?        @db.Uuid
  driver         User?          @relation(fields: [driverId], references: [id])
  
  vehicleId      String?        @db.Uuid
  vehicle        Vehicle?       @relation(fields: [vehicleId], references: [id])
  
  departureTime  DateTime       @db.Timestamptz
  estimatedEndTime DateTime?    @db.Timestamptz
  
  status         TripStatus     @default(SCHEDULED)
  totalSeats     Int            @default(14) @db.SmallInt
  remainingSeats Int            @default(14) @db.SmallInt

  completedStopIds String[]     @default([])

  createdAt      DateTime       @default(now()) @db.Timestamptz
  updatedAt      DateTime       @updatedAt @db.Timestamptz

  bookings       Booking[]
  transactions   Transaction[]
}

model Vehicle {
  id             String         @id @default(uuid()) @db.Uuid
  licensePlate   String         @unique @db.VarChar(20)
  make           String         @db.VarChar(50)
  model          String         @db.VarChar(50)
  year           Int?
  color          String?        @db.VarChar(30)
  capacity       Int            @default(14) @db.SmallInt
  
  // Link to the driver who owns/operates this vehicle
  ownerId        String?        @db.Uuid
  owner          User?          @relation("VehicleOwner", fields: [ownerId], references: [id])
  
  isActive       Boolean        @default(true)
  
  createdAt      DateTime       @default(now()) @db.Timestamptz
  updatedAt      DateTime       @updatedAt @db.Timestamptz

  tripInstances  TripInstance[]
}
