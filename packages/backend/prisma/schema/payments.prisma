enum TransactionType {
  TRIP_PAYMENT
  DRIVER_EARNING
  PLATFORM_COMMISSION
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Transaction {
  id             String            @id @default(uuid()) @db.Uuid
  amount         Decimal           @db.Decimal(10, 2)
  currency       String            @default("EGP") @db.VarChar(3)
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  description    String?           @db.Text

  riderId        String?           @db.Uuid
  rider          User?             @relation("RiderTransaction", fields: [riderId], references: [id])

  driverId       String?           @db.Uuid
  driver         User?             @relation("DriverTransaction", fields: [driverId], references: [id])

  tripInstanceId String?           @db.Uuid
  tripInstance   TripInstance?     @relation(fields: [tripInstanceId], references: [id])

  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz

  @@index([createdAt])
  @@index([type])
  @@index([driverId])
}
